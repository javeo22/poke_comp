SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
ANTHROPIC_API_KEY=sk-ant-your-key
CORS_ORIGINS=http://localhost:3000
SUPABASE_JWT_SECRET=your-jwt-secret
# Shared secret for Vercel Cron invocations of /admin/cron/* endpoints.
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
# Then: vercel env add CRON_SECRET production preview
CRON_SECRET=your-128-bit-hex-secret
